// Firestore security rules for the OpMo Endurance signup collections.
//
// ⚠ The Firebase project (operation-motorsport-scoring) is shared with other
// OpMo apps. Do NOT replace your existing rules with this file wholesale —
// copy the two `match` blocks below INTO your existing ruleset, alongside
// the match blocks your other apps rely on. See FIREBASE-SETUP.md.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /endurance_races/{raceId} {
      allow read: if true;
      // Race creation is open (the Add Race button is public in the UI).
      allow create: if true;
      // Editing, results entry, team management, deletion: TP only.
      allow update, delete: if request.auth != null;
    }

    match /endurance_registrations/{regId} {
      allow read: if true;
      // Drivers may register themselves, but never pre-assigned to a car.
      allow create: if request.resource.data.carId == null;
      // Drivers may withdraw their own entry while still unassigned;
      // the TP can delete anything.
      allow delete: if request.auth != null || resource.data.carId == null;
      // Car assignment / unassignment: TP only.
      allow update: if request.auth != null;
    }
  }
}
